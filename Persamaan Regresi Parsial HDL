        "# Import Libraries\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from statsmodels.formula.api import ols\n",
        "import numpy as np\n",
        "\n",
        "# --- 1. Membaca Data dan Membersihkan Kolom Tak Terpakai ---\n",
        "try:\n",
        "    # Membaca data Excel\n",
        "    df = pd.read_excel(\"Row Data Tugas 3.xlsx\")\n",
        "\n",
        "    # Menghapus kolom yang tidak relevan (Unnamed) yang muncul karena format Excel\n",
        "    # Identifikasi kolom yang mengandung 'Unnamed:'\n",
        "    cols_to_drop = [col for col in df.columns if 'Unnamed:' in col]\n",
        "    if cols_to_drop:\n",
        "        df = df.drop(columns=cols_to_drop)\n",
        "\n",
        "    print(\"5 Data Teratas Setelah Pembersihan Kolom:\")\n",
        "    print(df.head())\n",
        "    print(\"\\n--- Analisis Dimulai ---\\n\")\n",
        "\n",
        "except FileNotFoundError:\n",
        "    print(\"Error: File 'Row Data Tugas 3.xlsx' tidak ditemukan. Pastikan nama file sudah benar.\")\n",
        "    exit()\n",
        "\n",
        "# Daftar variabel independen yang dianalisis\n",
        "independent_vars = ['AGE', 'LDL', 'HDL']\n",
        "dependent_var = 'Y'\n",
        "\n",
        "# --- 2. Visualisasi Data Multivariat (Scatter Plot) [Soal No. 1] ---\n",
        "\n",
        "print(\"## 1. Visualisasi Data (Scatter Plot)\")\n",
        "\n",
        "for col in independent_vars:\n",
        "    plt.figure(figsize=(6, 4))\n",
        "    plt.scatter(df[col], df[dependent_var], color='darkblue', alpha=0.6)\n",
        "\n",
        "    # Menambahkan garis regresi sederhana untuk tren visual\n",
        "    m, c = np.polyfit(df[col], df[dependent_var], 1)\n",
        "    plt.plot(df[col], m*df[col] + c, color='red', linestyle='--')\n",
        "\n",
        "    plt.xlabel(col)\n",
        "    plt.ylabel(f'{dependent_var} (Perkembangan Penyakit)')\n",
        "    plt.title(f'Scatter Plot {col} terhadap {dependent_var}')\n",
        "    plt.grid(True, linestyle=':', alpha=0.7)\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# --- 3. Menentukan Model Persamaan Regresi Linear [Soal No. 2] ---\n",
        "\n",
        "# A. Model Regresi Linear Simultan (Berganda)\n",
        "print(\"\\n## 2.A. Model Regresi Linear Simultan (Berganda)\")\n",
        "\n",
        "# Membuat formula regresi dari daftar variabel independen\n",
        "formula_simultan = f'{dependent_var} ~ {\" + \".join(independent_vars)}'\n",
        "\n",
        "# Fitting Model\n",
        "model_simultan = ols(formula_simultan, data=df).fit()\n",
        "\n",
        "print(\"\\n--- Hasil Model Simultan ---\")\n",
        "print(model_simultan.summary())\n",
        "\n",
        "# Menyusun Persamaan Model Simultan\n",
        "B0 = model_simultan.params['Intercept']\n",
        "B_age = model_simultan.params['AGE']\n",
        "B_ldl = model_simultan.params['LDL']\n",
        "B_hdl = model_simultan.params['HDL']\n",
        "\n",
        "print(\"\\n-------------------------------------------------------------\")\n",
        "print(\"Persamaan Regresi Simultan (Dibulatkan):\")\n",
        "print(f\"{dependent_var} = {B0:.3f} + ({B_age:.3f} * AGE) + ({B_ldl:.3f} * LDL) + ({B_hdl:.3f} * HDL)\")\n",
        "print(\"-------------------------------------------------------------\\n\")\n",
        "\n",
        "# B. Model Regresi Linear Parsial (Sederhana)\n",
        "print(\"\\n## 2.B. Model Regresi Linear Parsial (Sederhana)\")\n",
        "\n",
        "for col in independent_vars:\n",
        "    # Persamaan model parsial\n",
        "    formula_partial = f'{dependent_var} ~ {col}'\n",
        "    model_partial = ols(formula_partial, data=df).fit()\n",
        "\n",
        "    # Menampilkan summary model parsial\n",
        "    print(f\"\\n--- Hasil Model Parsial: {col} terhadap {dependent_var} ---\")\n",
        "    print(model_partial.summary())\n",
        "\n",
        "    # Menyusun Persamaan Model Parsial\n",
        "    P_B0 = model_partial.params['Intercept']\n",
        "    P_B_col = model_partial.params[col]\n",
        "    print(f\"\\nPersamaan Regresi Parsial {col} (Dibulatkan):\")\n",
        "    print(f\"{dependent_var} = {P_B0:.3f} + ({P_B_col:.3f} * {col})\")"
      ]
